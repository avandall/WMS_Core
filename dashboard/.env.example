# Dashboard local/dev environment example.
# Point this at the API Gateway, not directly at downstream services.

API_GATEWAY_URL=http://localhost:8000
DASHBOARD_GATEWAY_TIMEOUT=20
# JWT secret must match the identity service SECRET_KEY for token validation
DASHBOARD_DEV_JWT_SECRET=replace-with-local-dev-secret
DASHBOARD_DEV_JWT_ALGORITHM=HS256
