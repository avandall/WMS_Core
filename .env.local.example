# =============================================================================
# WMS Core — Root Local Dev Environment
# =============================================================================
# HOW TO USE:
#   1. Copy this file to `.env.local`:
#         cp .env.local.example .env.local
#   2. Fill in any value marked CHANGE_ME.
#   3. Run docker compose:
#         docker compose --env-file .env.local up
#
# RULE: This file is the SINGLE SOURCE OF TRUTH for the local dev stack.
# Variables defined here flow into every service via docker-compose.yml.
# Service-specific .env.example files remain so each service can still be
# run standalone outside of compose (e.g. unit testing / debugging a service).
#
# NEVER commit a filled-in .env.local — it is git-ignored.
# =============================================================================


# ---------------------------------------------------------------------------
# [SHARED] Security
# One secret key shared by all services (JWT signing, internal auth).
# In production each service gets its own key from the Secret Manager.
# ---------------------------------------------------------------------------
SECRET_KEY=replace-with-local-dev-secret
JWT_ALGORITHM=HS256


# ---------------------------------------------------------------------------
# [SHARED] Python runtime
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
DEBUG=false


# ---------------------------------------------------------------------------
# [SHARED] Event Bus  (Redis Streams)
# Changing this URL is the only thing needed to swap Redis -> managed Redis.
# ---------------------------------------------------------------------------
EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
EVENTS_ENABLED=1


# ---------------------------------------------------------------------------
# [SHARED] Observability — OpenTelemetry + Logging
# To switch to a cloud provider (Datadog, New Relic…) just change ENDPOINT.
# ---------------------------------------------------------------------------
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json


# ---------------------------------------------------------------------------
# [SHARED] gRPC TLS (disabled locally; enable in prod via Secret Manager)
# ---------------------------------------------------------------------------
GRPC_TLS_ENABLED=0
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CLIENT_CA_FILE=
GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=


# ---------------------------------------------------------------------------
# [SHARED] Database Connection Pool (same tuning for all services locally)
# ---------------------------------------------------------------------------
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=5
DB_POOL_RECYCLE=1800
LOCAL_DB_BOOTSTRAP_ENABLED=1


# =============================================================================
# [PER-SERVICE] Database URLs
# Each service owns its own isolated database.
# Swap sqlite -> postgresql://user:pass@host:5432/db to use prod-like DB.
# =============================================================================
IDENTITY_DATABASE_URL=sqlite:////data/wms-identity.db
CUSTOMER_DATABASE_URL=sqlite:////data/wms-customer.db
PRODUCT_DATABASE_URL=sqlite:////data/wms-product.db
WAREHOUSE_DATABASE_URL=sqlite:////data/wms-warehouse.db
INVENTORY_DATABASE_URL=sqlite:////data/wms-inventory.db
DOCUMENTS_DATABASE_URL=sqlite:////data/wms-documents.db
AUDIT_DATABASE_URL=sqlite:////data/wms-audit.db
REPORTING_DATABASE_URL=sqlite:////data/wms-reporting.db


# =============================================================================
# [API GATEWAY] — gRPC upstream addresses & gateway settings
# =============================================================================
IDENTITY_GRPC_ADDR=identity-service:50051
CUSTOMER_GRPC_ADDR=customer-service:50052
PRODUCT_GRPC_ADDR=product-service:50053
WAREHOUSE_GRPC_ADDR=warehouse-service:50054
INVENTORY_GRPC_ADDR=inventory-service:50055
DOCUMENTS_GRPC_ADDR=documents-service:50056
AUDIT_GRPC_ADDR=audit-service:50057
REPORTING_GRPC_ADDR=reporting-service:50058
AI_GRPC_ADDR=ai-service:50059

GRPC_TIMEOUT_FAST=5
GRPC_TIMEOUT_DEFAULT=10
GRPC_TIMEOUT_SLOW=30
GRPC_TIMEOUT_AI=180
GRPC_RETRY_ATTEMPTS=2
GRPC_RETRY_BACKOFF_SECONDS=0.05
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=15

CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=0
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_RPS=10


# =============================================================================
# [IDENTITY SERVICE] — token expiry
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
RATE_LIMIT_PER_MINUTE=300


# =============================================================================
# [INVENTORY SERVICE] — event consumer config
# =============================================================================
INVENTORY_MOVEMENT_CONSUMER_ENABLED=1
INVENTORY_DLQ_STREAM=wms.events.inventory.dlq
INVENTORY_CONSUMER_MAX_ATTEMPTS=3
INVENTORY_RECLAIM_IDLE_MS=60000


# =============================================================================
# [AUDIT SERVICE] — event consumer config
# =============================================================================
AUDIT_EVENT_CONSUMER_ENABLED=1
AUDIT_EVENT_CONSUMER_START_ID=$
AUDIT_EVENT_CONSUMER_BLOCK_MS=5000
AUDIT_EVENT_CONSUMER_BATCH_SIZE=20
AUDIT_EVENT_CONSUMER_MAX_STREAM_LENGTH=10000
AUDIT_EVENT_CONSUMER_GROUP=audit-service
AUDIT_EVENT_CONSUMER_NAME=audit-service-1
AUDIT_EVENT_DLQ_STREAM=wms.events.audit.dlq
AUDIT_EVENT_CONSUMER_MAX_ATTEMPTS=3
AUDIT_EVENT_CONSUMER_RECLAIM_IDLE_MS=60000


# =============================================================================
# [REPORTING SERVICE] — read-model consumer config
# =============================================================================
REPORTING_READ_MODEL_CONSUMER_ENABLED=1
REPORTING_READ_MODEL_CONSUMER_GROUP=reporting-service
REPORTING_READ_MODEL_CONSUMER_NAME=reporting-service-1
REPORTING_READ_MODEL_CONSUMER_START_ID=0
REPORTING_READ_MODEL_DLQ_STREAM=wms.events.reporting.dlq


# =============================================================================
# [DASHBOARD] — internal gateway config
# =============================================================================
API_GATEWAY_URL=http://api-gateway:8000
DASHBOARD_GATEWAY_TIMEOUT=185
DASHBOARD_DEV_JWT_SECRET=replace-with-local-dev-secret
DASHBOARD_DEV_JWT_ALGORITHM=HS256


# =============================================================================
# [AI SERVICE] — optional, only used when --profile ai is active
# =============================================================================
AI_REINDEX_CONSUMER_ENABLED=0
AI_REINDEX_QUEUE_PATH=/tmp/wms-ai-reindex-queue.jsonl
AI_REINDEX_CONSUMER_GROUP=ai-service
AI_REINDEX_CONSUMER_NAME=ai-service-1
AI_REINDEX_DLQ_STREAM=wms.events.ai.dlq
AI_REINDEX_CONSUMER_BLOCK_MS=5000
AI_REINDEX_CONSUMER_BATCH_SIZE=10
AI_REINDEX_CONSUMER_MAX_ATTEMPTS=3
AI_REINDEX_CONSUMER_RECLAIM_IDLE_MS=60000
AI_REINDEX_CONSUMER_START_ID=0
FINE_TUNED_MODEL_PATH=training/fine_tuning/wms_final_adapter
FINE_TUNED_MODEL_DEVICE=cuda
FINE_TUNED_MAX_NEW_TOKENS=256
AI_BACKEND_QUERY_URL=http://api-gateway:8000/api/v1/ai/backend-query
AI_BACKEND_QUERY_TOKEN=
AI_BACKEND_QUERY_TIMEOUT=10
