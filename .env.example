# Example environment file (do not put secrets here).
#
# Copy to `.env` and fill in real values.

# Database Configuration
DATABASE_URL=postgresql://wms_user:CHANGE_ME@localhost:5433/warehouse_db

# Test Database Configuration (for testing)
TEST_DATABASE_URL=sqlite:///test.db

# Database Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Application Settings
DEBUG=False
TITLE=Warehouse Management API
VERSION=1.0.0
DESCRIPTION=A FastAPI application for warehouse management

# Server Settings
HOST=0.0.0.0
PORT=8080

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Security Settings
SECRET_KEY=CHANGE_ME
API_KEY_HEADER=X-API-Key

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]


# AI Engine (LangChain)
# Pick one provider: groq | gemini | openai
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
AI_TEMPERATURE=0.0
AI_DB_MAX_ROWS=50

# Provider API keys (set ONE of these depending on AI_PROVIDER)
GROQ_API_KEY=CHANGE_ME
GOOGLE_API_KEY=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
