# Inventory Service local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1
DATABASE_URL=sqlite:////tmp/wms-inventory.db
INIT_DB_TABLES=inventory,warehouse_inventory,inventory_movement_ledger
LOCAL_DB_BOOTSTRAP_ENABLED=1
SECRET_KEY=replace-with-local-dev-secret
TEST_DATABASE_URL=sqlite:////tmp/wms-inventory-test.db

DB_POOL_SIZE=50
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=5
DB_POOL_RECYCLE=1800

DEBUG=false
TESTING=false
TITLE=Inventory Service
VERSION=0.1.0
DESCRIPTION=Inventory service for WMS
HOST=0.0.0.0
PORT=8000
RATE_LIMIT_PER_MINUTE=300
API_KEY_HEADER=X-API-Key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
EVENTS_ENABLED=1
INVENTORY_MOVEMENT_CONSUMER_ENABLED=1
INVENTORY_DLQ_STREAM=wms.events.inventory.dlq
INVENTORY_CONSUMER_MAX_ATTEMPTS=3
INVENTORY_RECLAIM_IDLE_MS=60000

GRPC_TLS_ENABLED=0
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CLIENT_CA_FILE=
GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
