# AI Service local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1

# Core AI configuration
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
EVALUATOR_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

VECTOR_DB_PATH=/tmp/wms-ai-vector-db
DB_CONNECTION_STRING=sqlite:////tmp/wms-ai.db

RETRIEVAL_K=3
BM25_WEIGHT=0.5
VECTOR_WEIGHT=0.5
QUALITY_THRESHOLD=5.0

GROQ_API_KEY=replace-with-groq-api-key

# Optional fine-tuned local extractor for structured data-query templates only.
# Point this to the exported local model folder that contains config/tokenizer/weights.
# Example after training: training/fine_tuning/wms_final_model
FINE_TUNED_MODEL_PATH=
# Use cpu by default; switch to cuda, mps, or a GPU index like 0 if available.
FINE_TUNED_MODEL_DEVICE=cpu
# Keep this small so the extractor returns short JSON instead of long text.
FINE_TUNED_MAX_NEW_TOKENS=256

# Event-driven reindexing
EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
AI_REINDEX_CONSUMER_ENABLED=0
AI_REINDEX_QUEUE_PATH=/tmp/wms-ai-reindex-queue.jsonl
AI_REINDEX_CONSUMER_GROUP=ai-service
AI_REINDEX_CONSUMER_NAME=ai-service-1
AI_REINDEX_DLQ_STREAM=wms.events.ai.dlq
AI_REINDEX_CONSUMER_BLOCK_MS=5000
AI_REINDEX_CONSUMER_BATCH_SIZE=10
AI_REINDEX_CONSUMER_MAX_ATTEMPTS=3
AI_REINDEX_CONSUMER_RECLAIM_IDLE_MS=60000
AI_REINDEX_CONSUMER_START_ID=0

# Structured backend query adapter
AI_BACKEND_QUERY_URL=
AI_BACKEND_QUERY_TOKEN=
AI_BACKEND_QUERY_TIMEOUT=10

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
