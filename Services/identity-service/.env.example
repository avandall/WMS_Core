# Identity Service local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1
DATABASE_URL=sqlite:////tmp/wms-identity.db
INIT_DB_TABLES=users
LOCAL_DB_BOOTSTRAP_ENABLED=1
SECRET_KEY=replace-with-local-dev-secret

GRPC_TLS_ENABLED=0
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CLIENT_CA_FILE=
GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
