# Audit Service local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1
DATABASE_URL=sqlite:////tmp/wms-audit.db
INIT_DB_TABLES=audit_events
LOCAL_DB_BOOTSTRAP_ENABLED=1
SECRET_KEY=replace-with-local-dev-secret

EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
EVENTS_ENABLED=1
AUDIT_EVENT_CONSUMER_ENABLED=1
AUDIT_EVENT_CONSUMER_START_ID=$
AUDIT_EVENT_CONSUMER_BLOCK_MS=5000
AUDIT_EVENT_CONSUMER_BATCH_SIZE=20
AUDIT_EVENT_CONSUMER_MAX_STREAM_LENGTH=10000
AUDIT_EVENT_CONSUMER_GROUP=audit-service
AUDIT_EVENT_CONSUMER_NAME=audit-service-1
AUDIT_EVENT_DLQ_STREAM=wms.events.audit.dlq
AUDIT_EVENT_CONSUMER_MAX_ATTEMPTS=3
AUDIT_EVENT_CONSUMER_RECLAIM_IDLE_MS=60000

GRPC_TLS_ENABLED=0
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CLIENT_CA_FILE=
GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
