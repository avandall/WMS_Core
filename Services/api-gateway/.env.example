# API Gateway local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1
SECRET_KEY=replace-with-local-dev-secret
DEBUG=false
TITLE=WMS API Gateway
VERSION=0.1.0
DESCRIPTION=Public REST gateway for WMS microservices
HOST=0.0.0.0
PORT=8000
API_KEY_HEADER=X-API-Key

IDENTITY_GRPC_ADDR=identity-service:50051
CUSTOMER_GRPC_ADDR=customer-service:50052
PRODUCT_GRPC_ADDR=product-service:50053
WAREHOUSE_GRPC_ADDR=warehouse-service:50054
INVENTORY_GRPC_ADDR=inventory-service:50055
DOCUMENTS_GRPC_ADDR=documents-service:50056
AUDIT_GRPC_ADDR=audit-service:50057
REPORTING_GRPC_ADDR=reporting-service:50058

GRPC_TIMEOUT_FAST=5
GRPC_TIMEOUT_DEFAULT=10
GRPC_TIMEOUT_SLOW=30
GRPC_RETRY_ATTEMPTS=2
GRPC_RETRY_BACKOFF_SECONDS=0.05
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=15

GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=

CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=0
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_RPS=10

EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
EVENTS_ENABLED=1

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
