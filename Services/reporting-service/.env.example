# Reporting Service local/dev environment example.
# Copy to `.env` only for local runs; production values should come from the platform secret manager.

PYTHONUNBUFFERED=1
DATABASE_URL=sqlite:////tmp/wms-reporting.db
INIT_DB_TABLES=reporting_read_model_events,inventory_summary,document_summary,sales_summary,warehouse_activity_summary
LOCAL_DB_BOOTSTRAP_ENABLED=1
SECRET_KEY=replace-with-local-dev-secret

EVENT_BUS_URL=redis://event-bus:6379/0
EVENT_STREAM=wms.events
EVENTS_ENABLED=1
REPORTING_READ_MODEL_CONSUMER_ENABLED=1
REPORTING_READ_MODEL_CONSUMER_GROUP=reporting-service
REPORTING_READ_MODEL_CONSUMER_NAME=reporting-service-1
REPORTING_READ_MODEL_CONSUMER_START_ID=0
REPORTING_READ_MODEL_DLQ_STREAM=wms.events.reporting.dlq

GRPC_TLS_ENABLED=0
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CLIENT_CA_FILE=
GRPC_CLIENT_TLS_ENABLED=0
GRPC_CLIENT_ROOT_CERT_FILE=
GRPC_CLIENT_CERT_FILE=
GRPC_CLIENT_KEY_FILE=

OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_FORMAT=json
